---
interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  href: string;
  technologies: string[];
}

const {
  title,
  description,
  image,
  imageAlt,
  href,
  technologies,
} = Astro.props;
---

<article class="project-card">
  <img
    class="project-card-image"
    src={image}
    alt={imageAlt}
    loading="lazy"
  />

  <div class="project-card-content">
    <h3>{title}</h3>

    <p>{description}</p>

    <ul class="technology-list" aria-label="Technologies used">
      {
        technologies.map((technology) => (
          <li>{technology}</li>
        ))
      }
    </ul>

    <a class="project-link" href={href}>
      View project →
    </a>
  </div>
</article>