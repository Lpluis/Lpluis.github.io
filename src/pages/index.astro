---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
---

<BaseLayout title="Luis Leon  Pineda| Electrical Engineer">
  <section class="hero container">
    <div class="hero-content">
      <p class="eyebrow">Electrical Engineer</p>

      <h1>
        FPGA, embedded systems, PCB design, and hardware verification
      </h1>

      <p class="hero-description">
        I develop and validate FPGA and embedded systems, integrating digital logic, 
        firmware, mixed-signal hardware, and board-level interfaces from concept 
        through bring-up and verification.
      </p>

      <div class="button-row">
        <a class="button primary-button" href="/projects/">
          View Projects
        </a>

        <a
          class="button secondary-button"
          href="/documents/Luis_Leon_Resume.pdf"
          target="_blank"
        >
          View Resume
        </a>
      </div>
    </div>
  </section>

  <section class="section container">
    <div class="section-heading">
      <p class="eyebrow">Technical Work</p>
      <h2>Featured Projects</h2>

      <p class="section-description">
        Selected work covering FPGA development, embedded systems,
        mixed-signal hardware, verification, and board-level testing.
      </p>
    </div>


    <div class="project-grid">
      <ProjectCard
        title="Capstone FPGA Curriculum Platform"
        description="Educational FPGA platform designed to give engineering students practical experience with digital design, embedded systems, and hardware/software integration. The project combined reusable SystemVerilog modules, AXI-based peripherals, guided laboratory procedures, technical documentation, and hardware demonstrations on a Zynq-7000 development board."
        image="/images/CoraZ7.jpeg"
        imageAlt="Zynq-7000 FPGA curriculum platform developed for hands-on engineering education"
        href="/projects/capstone-fpga-curriculum-platform/"
        technologies={[
          'SystemVerilog',
          'Zynq-7000',
          'AXI4-Lite',
          'FPGA Verification',
          'Vivado',
          'Embedded C',
          'Curriculum Development',
        ]}
      />

      <ProjectCard
        title="FPGA Autonomous Robot"
        description="SystemVerilog autonomous controller using a Zynq-7000 SoC, ultrasonic sensing, infrared boundary detection, PWM motor control, and finite-state-machine navigation."
        image="/images/FPGA_Bot.jpeg"
        imageAlt="FPGA autonomous robot"
        href="/projects/fpga-autonomous-robot/"
        technologies={[
          'SystemVerilog',
          'Vivado',
          'Zynq-7000',
          'PWM',
        ]}
      />

      <ProjectCard
        title="BCG Data Acquisition PCB"
        description="Mixed-signal PCB development, hardware bring-up, signal validation, troubleshooting, and cost-reduction work for a BCG data-acquisition platform."
        image="/images/bcg-pcb/pcb.jpg"
        imageAlt="Mixed-signal BCG data acquisition PCB"
        href="/projects/bcg-pcb/"
        technologies={[
          'PCB Design',
          'Mixed Signal',
          'Oscilloscope',
          'Validation',
        ]}
      />

      <ProjectCard
        title="ESP32-C6 Sensor Web Server"
        description="Wi-Fi-enabled embedded monitoring platform that collects sensor measurements and displays them through a browser-based dashboard."
        image="/images/esp32-server/dashboard.png"
        imageAlt="ESP32-C6 sensor web dashboard"
        href="/projects/esp32-web-server/"
        technologies={[
          'ESP32-C6',
          'C++',
          'I2C',
          'HTML',
        ]}
      />
    </div>
  </section>
</BaseLayout>