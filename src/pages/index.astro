---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
---

<BaseLayout title="Luis Leon Pineda | Electrical Engineer">
  <section class="hero container">
    <div class="hero-content">

      <div class="construction-notice" role="status">
        <strong>Portfolio under construction.</strong>
        This site is actively being developed, and additional projects,
        documentation, and technical details are being added.
      </div>

      <p class="eyebrow">Electrical Engineer</p>
      <h1>
        FPGA, embedded systems, PCB design, and hardware verification
      </h1>

      <p class="hero-description">
        I develop and validate FPGA and embedded systems, integrating digital logic, 
        firmware, mixed-signal hardware, and board-level interfaces from concept 
        through bring-up and verification.
      </p>

      <div class="button-row">
        <a class="button primary-button" href="/projects/">
          View Projects
        </a>

        <a
          class="button secondary-button"
          href="/documents/Luis Leon Pineda.pdf"
          target="_blank"
        >
          View Resume
        </a>
      </div>
    </div>
  </section>

  <section class="section container">
    <div class="section-heading">
      <p class="eyebrow">Technical Work</p>
      <h2>Featured Projects</h2>

      <p class="section-description">
        Selected work covering FPGA development, embedded systems,
        mixed-signal hardware, verification, and board-level testing.
      </p>
    </div>


    <div class="project-grid">
      <ProjectCard
        title="404: Bot Not Found"
        description="An educational FPGA and embedded-systems platform developed by an eight-person senior design team using the Digilent Cora Z7. I served as project manager and master XSA integration owner, bringing together AXI-connected GPIO, SPI, I2C, and PWM peripherals, embedded software, simulation, hardware deployment, verification, and an autonomous robot extension."
        image="/images/capstone-platform/Complete_Cora_PCB.jpg"
        imageAlt="Complete Cora Z7 educational platform with its custom peripheral PCB, IMU sensor, and OLED displays"
        href="/projects/capstone-fpga-curriculum-platform/"
        technologies={[
          'SystemVerilog',
          'Cora Z7',
          'AXI4-Lite',
          'Vivado',
          'Embedded C',
          'FPGA Verification',
          'Autonomous Robotics',
        ]}
      />

      <ProjectCard
        title="AI-Assisted Engineering Portfolio"
        description="A living Astro and GitHub Pages project I use to learn AI-assisted development, VS Code, HTML, CSS, Git, debugging, accessibility, and iterative web design while documenting my engineering work."
        image="/images/githubwebpage/Webpage.jpg"
        imageAlt="Luis Leon Pineda engineering portfolio displayed in a web browser"
        href="/projects/github-pages-website/"
        technologies={[
          'Astro',
          'HTML',
          'CSS',
          'VS Code',
          'GitHub Pages',
          'AI-Assisted Development',
        ]}
      />

      <ProjectCard
        title="256-Bit Matrix Soft Processor"
        description="A modular SystemVerilog processor built around a shared 256-bit tri-state bus, with dedicated matrix and integer ALUs, a multi-cycle execution engine, and automated Vivado/XSim verification."
        image="/images/hdl-final-project/execution-machine-waves.jpg"
        imageAlt="Vivado waveform simulation of the 256-bit matrix soft processor execution engine"
        href="/projects/hdl-final-project/"
        technologies={[
          'SystemVerilog',
          'Vivado',
          'XSim',
          'Processor Architecture',
          'Finite-State Machines',
          'Matrix ALU',
        ]}
      />

      <ProjectCard
        title="Ballistocardiogram (BCG) Data-Acquisition PCB"
        description="Mixed-signal PCB development, hardware bring-up, signal validation, troubleshooting, and cost-reduction work for a ballistocardiogram (BCG) data-acquisition platform."
        image="/images/bcg-pcb/BCG_PCB1.jpg"
        imageAlt="Mixed-signal ballistocardiogram data-acquisition PCB"
        href="/projects/bcg-pcb/"
        technologies={[
          'PCB Design',
          'Mixed Signal',
          'Oscilloscope',
          'Validation',
        ]}
      />

    </div>
  </section>
</BaseLayout>
