---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
---

<BaseLayout
  title="Engineering Projects | Luis Leon Pineda"
  description="FPGA, embedded systems, PCB, verification, and hardware projects."
>
  <section class="page-header container">
    <p class="eyebrow">Portfolio</p>
    <h1>Engineering Projects</h1>

    <p class="hero-description">
      Detailed project documentation covering requirements, architecture,
      implementation, verification, debugging, and results.
    </p>
  </section>

  <section class="section container">
    <div class="project-grid">
      <ProjectCard
        title="HDL FPGA 404: BOT_Not_Found"
        description="Educational FPGA platform designed to give engineering students practical experience with digital design, embedded systems, and hardware/software integration. The project combined reusable SystemVerilog modules, AXI-based peripherals, guided laboratory procedures, technical documentation, and hardware demonstrations on a Zynq-7000 development board."
        image="/images/CoraZ7.jpeg"
        imageAlt="Zynq-7000 FPGA curriculum platform developed for hands-on engineering education"
        href="/projects/capstone-fpga-curriculum-platform/"
        technologies={[
          'SystemVerilog',
          'Zynq-7000',
          'AXI',
          'FPGA Verification',
          'Vivado',
          'Embedded C',
          'Curriculum Development',
        ]}
      />

      <ProjectCard
        title="AI-Assisted Engineering Portfolio"
        description="A living Astro and GitHub Pages project I use to learn AI-assisted development, VS Code, HTML, CSS, Git, debugging, accessibility, and iterative web design while documenting my engineering work."
        image="/images/githubwebpage/Webpage.jpg"
        imageAlt="Luis Leon Pineda engineering portfolio displayed in a web browser"
        href="/projects/github-pages-website/"
        technologies={[
          'Astro',
          'HTML',
          'CSS',
          'VS Code',
          'GitHub Pages',
          'AI-Assisted Development',
        ]}
      />

      <ProjectCard
        title="FPGA Autonomous Robot"
        description="SystemVerilog autonomous controller using a Zynq-7000 SoC, ultrasonic sensing, infrared boundary detection, PWM motor control, and finite-state-machine navigation."
        image="/images/FPGA_Bot.jpeg"
        imageAlt="FPGA autonomous robot"
        href="/projects/fpga-autonomous-robot/"
        technologies={[
          'SystemVerilog',
          'Vivado',
          'Zynq-7000',
          'PWM',
        ]}
      />

      <ProjectCard
        title="BCG Data Acquisition PCB"
        description="Mixed-signal PCB development, hardware bring-up, signal validation, troubleshooting, and cost-reduction work for a BCG data-acquisition platform."
        image="/images/bcg-pcb/BCG_PCB1.jpg"
        imageAlt="Mixed-signal BCG data acquisition PCB"
        href="/projects/bcg-pcb/"
        technologies={[
          'PCB Design',
          'Mixed Signal',
          'Oscilloscope',
          'Validation',
        ]}
      />

    </div>
  </section>
</BaseLayout>
